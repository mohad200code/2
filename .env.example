# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google OAuth credentials (automatically set by AI Studio when Gmail flow is accepted)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe Merchant Gateway Configuration
# Add these variables to enable real payment processing!
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# SMTP Automated Email Verification Configurations
# Add your Gmail or SMTP credentials to dispatch live signup verification codes!
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Production Custom Domain Mapping
# Bind your free, secure custom domain (sdazum.com) on Google Cloud Console!
# 1. Go to Google Cloud Console > Cloud Run
# 2. Select this service and click "Manage Custom Domains"
# 3. Add 'sdazum.com' (and 'www.sdazum.com')
# 4. Configure your DNS Registrar (e.g. GoDaddy, Namecheap) with the provided DNS records
# 5. Cloud Run will provision a FREE, SECURE SSL certificate (HTTPS) that renews forever!
PRODUCTION_CUSTOM_DOMAIN="sdazum.com"

